---
import { siteConfig } from '../../config/site';

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const siteUrl = Astro.site ? new URL(url, Astro.site).toString() : `${siteConfig.siteUrl}${url}`;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(siteUrl);

const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const emailShareUrl = `mailto:?subject=${encodedTitle}&body=${encodeURIComponent(`Worth a read: ${siteUrl}`)}`;
---

<div class="flex items-center gap-4 my-8 pb-8 border-b border-[var(--border-color)]">
  <span class="text-sm font-medium text-[var(--text-muted)]">Share this analysis:</span>
  <div class="flex items-center gap-2">
    <a 
      href={emailShareUrl}
      class="p-2 rounded-lg bg-[var(--border-color)] hover:bg-primary-600 hover:text-white text-[var(--text-color)] transition-colors shadow-sm focus:ring-2 focus:ring-primary-500 focus:outline-none"
      aria-label="Share by email"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z"></path><path d="m22 8-8.97 5.7a2 2 0 0 1-2.06 0L2 8"></path></svg>
    </a>
    <a 
      href={linkedinUrl} 
      target="_blank" 
      rel="noopener noreferrer"
      class="p-2 rounded-lg bg-[var(--border-color)] hover:bg-[#0A66C2] hover:text-white text-[var(--text-color)] transition-colors shadow-sm focus:ring-2 focus:ring-primary-500 focus:outline-none"
      aria-label="Share on LinkedIn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
    </a>
    <button
      onclick={`navigator.clipboard.writeText('${siteUrl}').then(() => { const el = document.getElementById('copy-toast'); el.classList.remove('opacity-0'); setTimeout(() => el.classList.add('opacity-0'), 2000); })`}
      class="p-2 rounded-lg bg-[var(--border-color)] hover:bg-primary-600 hover:text-white text-[var(--text-color)] transition-colors shadow-sm focus:ring-2 focus:ring-primary-500 focus:outline-none relative group"
      aria-label="Copy link"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
      <span id="copy-toast" class="absolute -top-10 left-1/2 -translate-x-1/2 bg-base-900 text-white text-xs px-2 py-1 rounded opacity-0 transition-opacity pointer-events-none whitespace-nowrap">
        Copied!
      </span>
    </button>
  </div>
</div>
