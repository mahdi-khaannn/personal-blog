---
import { trustedLogos } from '../../data/trustedLogos';

const repeatedLogos = [...trustedLogos, ...trustedLogos];
---

<div class="ticker-shell">
  <div class="ticker-track" aria-label="Trusted by and working alongside">
    {repeatedLogos.map((logo, index) => (
      <span class="ticker-item" aria-hidden={index >= trustedLogos.length ? 'true' : 'false'}>
        <img
          src={logo.src}
          alt={index >= trustedLogos.length ? '' : logo.alt}
          class="ticker-logo"
          loading={index < trustedLogos.length ? 'eager' : 'lazy'}
          decoding="async"
        />
      </span>
    ))}
  </div>
</div>

<style>
  .ticker-shell {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .ticker-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: clamp(0.9rem, 1.6vw, 1.35rem);
    animation: trusted-scroll 108s linear infinite;
    will-change: transform;
  }

  .ticker-item {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(9.5rem, 11.5vw, 10.75rem);
    height: clamp(3.55rem, 4.25vw, 4.1rem);
    padding-inline: clamp(0.65rem, 1vw, 0.9rem);
    overflow: hidden;
  }

  .ticker-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.68;
    filter: brightness(0) invert(1);
    transform-origin: center;
    transition: opacity 180ms ease, filter 180ms ease, transform 180ms ease;
  }

  :global(:root:not(.dark)) .ticker-logo {
    opacity: 0.58;
    filter: brightness(0) saturate(0);
  }

  .ticker-shell:hover .ticker-logo {
    opacity: 0.84;
    filter: brightness(0) invert(1);
    transform: scale(1.02) translateY(-1px);
  }

  :global(:root:not(.dark)) .ticker-shell:hover .ticker-logo {
    opacity: 0.7;
    filter: brightness(0) saturate(0);
  }

  @keyframes trusted-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
