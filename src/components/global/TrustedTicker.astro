---
import { trustedLogos } from '../../data/trustedLogos';

const repeatedLogos = [...trustedLogos, ...trustedLogos];
---

<div class="ticker-shell">
  <div class="ticker-track" aria-label="Trusted by and working alongside">
    {repeatedLogos.map((logo, index) => (
      <span
        class="ticker-item"
        style={`--logo-width: ${logo.widthRem}rem; --logo-height: ${(logo.heightRem ?? 2.5)}rem; --logo-scale: ${(logo.scale ?? 1)};`}
        aria-hidden={index >= trustedLogos.length ? 'true' : 'false'}
      >
        <img
          src={logo.src}
          alt={index >= trustedLogos.length ? '' : logo.alt}
          class="ticker-logo"
          loading={index < trustedLogos.length ? 'eager' : 'lazy'}
          decoding="async"
        />
      </span>
    ))}
  </div>
</div>

<style>
  .ticker-shell {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .ticker-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.6rem);
    animation: trusted-scroll 108s linear infinite;
    will-change: transform;
  }

  .ticker-item {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(3.3rem, 4.4vw, 4.25rem);
    padding-inline: clamp(1rem, 2.2vw, 1.7rem);
    overflow: hidden;
  }

  .ticker-logo {
    width: auto;
    max-width: min(var(--logo-width), 24vw);
    height: clamp(2.2rem, var(--logo-height), 3.05rem);
    max-height: 100%;
    object-fit: contain;
    opacity: 0.68;
    filter: brightness(0) invert(1);
    transform: scale(var(--logo-scale));
    transform-origin: center;
    transition: opacity 180ms ease, filter 180ms ease, transform 180ms ease;
  }

  :global(:root:not(.dark)) .ticker-logo {
    opacity: 0.58;
    filter: brightness(0) saturate(0);
  }

  .ticker-shell:hover .ticker-logo {
    opacity: 0.84;
    filter: brightness(0) invert(1);
    transform: scale(calc(var(--logo-scale) * 1.02)) translateY(-1px);
  }

  :global(:root:not(.dark)) .ticker-shell:hover .ticker-logo {
    opacity: 0.7;
    filter: brightness(0) saturate(0);
  }

  @keyframes trusted-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
