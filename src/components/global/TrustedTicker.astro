---
import { trustedLogos } from '../../data/trustedLogos';

const repeatedLogos = [...trustedLogos, ...trustedLogos];
---

<div class="ticker-shell">
  <div class="ticker-track" aria-label="Trusted by and working alongside">
    {repeatedLogos.map((logo, index) => (
      <span
        class="ticker-item"
        style={`--logo-width: ${logo.widthRem}rem;`}
        aria-hidden={index >= trustedLogos.length ? 'true' : 'false'}
      >
        <img
          src={logo.src}
          alt={index >= trustedLogos.length ? '' : logo.alt}
          class="ticker-logo"
          loading={index < trustedLogos.length ? 'eager' : 'lazy'}
          decoding="async"
        />
      </span>
    ))}
  </div>
</div>

<style>
  .ticker-shell {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .ticker-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: clamp(0.75rem, 1.8vw, 1.25rem);
    animation: trusted-scroll 92s linear infinite;
    will-change: transform;
  }

  .ticker-item {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: clamp(0.9rem, 2vw, 1.6rem);
  }

  .ticker-logo {
    width: min(var(--logo-width), 18vw);
    max-width: none;
    max-height: clamp(1.75rem, 2.8vw, 2.7rem);
    height: auto;
    object-fit: contain;
    opacity: 0.52;
    filter: brightness(0) invert(1);
    transition: opacity 180ms ease, filter 180ms ease, transform 180ms ease;
  }

  :global(:root:not(.dark)) .ticker-logo {
    opacity: 0.32;
    filter: brightness(0) saturate(0);
  }

  .ticker-shell:hover .ticker-logo {
    opacity: 0.72;
    filter: brightness(0) invert(1);
    transform: translateY(-1px);
  }

  :global(:root:not(.dark)) .ticker-shell:hover .ticker-logo {
    opacity: 0.48;
    filter: brightness(0) saturate(0);
  }

  @keyframes trusted-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
