---
interface Props {
  class?: string;
  label?: string;
}

const { class: className = '', label = 'Mahdi' } = Astro.props;
---

<span
  class:list={['inline-flex items-end gap-[0.08em] leading-[0.88] select-none', className]}
  data-logo-wordmark
  aria-hidden="true"
>
  <span class="font-brand text-primary-500 tracking-[-0.08em] [transform:skewX(-10deg)] drop-shadow-[0_10px_24px_rgba(47,129,247,0.22)]">
    {label}
  </span>
  <span class="mb-[0.16em] block h-[0.18em] w-[0.18em] rounded-full bg-primary-400 shadow-[0_0_14px_rgba(96,165,250,0.75)]"></span>
</span>
