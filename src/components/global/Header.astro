---
import Navigation from './Navigation.astro';
import SearchModal from './SearchModal';
import DarkModeToggle from './DarkModeToggle';
import LogoWordmark from './LogoWordmark.astro';
---

<header class="sticky top-0 z-40 w-full border-b border-[var(--border-color)] bg-[var(--bg-color)]/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    
    <div class="flex items-center gap-2">
      <a
        href="/"
        class="group inline-flex items-center pt-1"
        aria-label="Home"
      >
        <LogoWordmark class="text-4xl sm:text-5xl transition-transform duration-300 group-hover:scale-[1.04] group-hover:-translate-y-0.5" />
      </a>
    </div>

    <div class="flex items-center gap-2 md:gap-4">
      <Navigation />
      <div class="flex items-center border-l border-[var(--border-color)] pl-2 md:pl-4 md:ml-2 gap-1 md:gap-2">
        <SearchModal client:load />
        <DarkModeToggle client:load />
      </div>
    </div>
    
  </div>
</header>
