---
import CalendarWidget from './CalendarWidget';
import LogoWordmark from './LogoWordmark.astro';
const currentYear = new Date().getFullYear();
---

<footer class="relative mt-auto overflow-hidden border-t border-[var(--border-color)] bg-[var(--surface-color)] text-[var(--text-muted)] pt-16 pb-8">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(47,129,247,0.16),transparent_38%)]"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary-500/40 to-transparent"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row justify-between gap-16 mb-16">
      
      <!-- Left: Copy & Branding -->
      <div class="lg:w-1/2 flex flex-col justify-between">
        <div>
          <LogoWordmark class="text-3xl md:text-4xl" />
          <h2 class="mt-6 text-4xl md:text-5xl font-display font-medium text-[var(--text-color)] mb-4 tracking-tight">
            See if we're a good fit.
          </h2>
          <p class="text-base md:text-lg text-[var(--text-muted)] max-w-md leading-relaxed mb-8">
            Book a session to talk through your orchestration challenges and what you're building.
          </p>
        </div>

        <!-- Links (GitHub Enterprise style columns) -->
        <div class="flex flex-col gap-8 mt-12 lg:mt-0 font-sans">
          
          <div>
            <h3 class="text-xs font-semibold text-[var(--text-color)]/75 uppercase tracking-[0.2em] mb-4">Content</h3>
            <ul class="space-y-3">
              <li><a href="/blog" class="text-sm hover:text-[var(--text-color)] transition-colors inline-flex">All Articles</a></li>
              <li><a href="/newsletter" class="text-sm hover:text-[var(--text-color)] transition-colors inline-flex">Newsletter</a></li>
              <li><a href="/tags/tutorial" class="text-sm hover:text-[var(--text-color)] transition-colors inline-flex">Tutorials</a></li>
            </ul>
          </div>

        </div>
      </div>

      <!-- Right: Tribe Design Calendar Mockup -->
      <div class="lg:w-[450px] shrink-0">
        <CalendarWidget client:load />
      </div>
      
    </div>
    
    <div class="border-t border-[var(--border-color)]/80 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-[var(--text-muted)] px-1">
      <div class="flex items-center gap-4 flex-wrap justify-center md:justify-start">
        <p>&copy; {currentYear} Mahdi Khan.</p>
        <a href="#" class="hover:text-[var(--text-color)] transition-colors">Terms</a>
        <a href="#" class="hover:text-[var(--text-color)] transition-colors">Privacy</a>
        <a href="#" class="hover:text-[var(--text-color)] transition-colors">Sitemap</a>
        <a href="/rss.xml" class="hover:text-[var(--text-color)] transition-colors">RSS Feed</a>
      </div>
      <div class="mt-4 md:mt-0 flex items-center space-x-4">
        <a href="https://www.linkedin.com/in/m-mahdi-khan/" target="_blank" rel="noopener noreferrer" class="hover:text-primary-500 transition-colors" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://github.com/mahdi-khaannn" target="_blank" rel="noopener noreferrer" class="hover:text-primary-500 transition-colors" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
        <a href="https://medium.com/@mahdikhan" target="_blank" rel="noopener noreferrer" class="hover:text-primary-500 transition-colors" aria-label="Medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
        </a>
        <a href="mailto:mahdi20312.khan@gmail.com" class="hover:text-primary-500 transition-colors" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 7.5v9a2.25 2.25 0 0 1-2.25 2.25h-15A2.25 2.25 0 0 1 2.25 16.5v-9m19.5 0A2.25 2.25 0 0 0 19.5 5.25h-15A2.25 2.25 0 0 0 2.25 7.5m19.5 0-8.69 5.791a1.875 1.875 0 0 1-2.12 0L2.25 7.5"></path></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
