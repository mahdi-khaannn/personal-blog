---
import CalendarWidget from './CalendarWidget';
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-[var(--border-color)] bg-[#010409] text-[var(--text-muted)] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row justify-between gap-16 mb-16">
      
      <!-- Left: Copy & Branding -->
      <div class="lg:w-1/2 flex flex-col justify-between">
        <div>
          <h2 class="text-4xl md:text-5xl font-display font-medium text-[#2f81f7] mb-4 tracking-tight">
            See if we're a good fit.
          </h2>
          <p class="text-base md:text-lg text-[var(--text-muted)] max-w-md leading-relaxed mb-8">
            Book a session to talk through your orchestration challenges and what you're building.
          </p>
        </div>

        <!-- Links (GitHub Enterprise style columns) -->
        <div class="flex flex-col gap-8 mt-12 lg:mt-0 font-sans">
          
          <div>
            <h3 class="text-xs font-semibold text-[var(--bg-color)] uppercase tracking-wider mb-4">Content</h3>
            <ul class="space-y-3">
              <li><a href="/blog" class="text-sm hover:text-primary-500 transition-colors inline-flex">All Articles</a></li>
              <li><a href="/newsletter" class="text-sm hover:text-primary-500 transition-colors inline-flex">Newsletter</a></li>
              <li><a href="/tags/tutorial" class="text-sm hover:text-primary-500 transition-colors inline-flex">Tutorials</a></li>
            </ul>
          </div>

        </div>
      </div>

      <!-- Right: Tribe Design Calendar Mockup -->
      <div class="lg:w-[450px] shrink-0">
        <CalendarWidget client:load />
      </div>
      
    </div>
    
    <div class="border-t border-[#21262d] pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-[var(--text-muted)] px-1">
      <div class="flex items-center gap-4 flex-wrap justify-center md:justify-start">
        <p>&copy; {currentYear} Mahdi Khan.</p>
        <a href="#" class="hover:text-primary-500 transition-colors">Terms</a>
        <a href="#" class="hover:text-primary-500 transition-colors">Privacy</a>
        <a href="#" class="hover:text-primary-500 transition-colors">Sitemap</a>
        <a href="/rss.xml" class="hover:text-primary-500 transition-colors">RSS Feed</a>
      </div>
      <div class="mt-4 md:mt-0 flex items-center space-x-4">
        <a href="https://linkedin.com/in/mahdikhan" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--bg-color)] transition-colors" aria-label="LinkedIn">
