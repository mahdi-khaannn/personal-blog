---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SpotlightCard from '../components/global/SpotlightCard';
import RotatingText from '../components/global/RotatingText';
import ScrollPath from '../components/global/ScrollPath';
import TrustedTicker from '../components/global/TrustedTicker.astro';

const latestPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Mahdi Khan - AI Agents & Orchestration">
  <!-- BACKGROUND DECOR (GitHub Enterprise Vibe) -->
  <div class="absolute top-0 inset-x-0 h-[960px] overflow-hidden pointer-events-none -z-10 select-none">
    <div class="absolute -top-[8%] left-1/2 -translate-x-1/2 w-[1200px] h-[560px] bg-primary-600/18 dark:bg-primary-500/12 blur-[120px] rounded-[100%]"></div>
    <div class="absolute -top-[16%] right-[6%] w-[420px] h-[420px] bg-primary-300/14 dark:bg-primary-400/8 blur-[80px] rounded-full"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808010_1px,transparent_1px),linear-gradient(to_bottom,#80808010_1px,transparent_1px)] bg-[size:48px_48px] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
  </div>

  <!-- HERO REGION -->
  <section class="relative py-16 md:py-24 px-4">
    <div class="max-w-5xl mx-auto flex flex-col items-center text-center">
      <h1 class="flex max-w-5xl flex-wrap items-center justify-center gap-x-5 gap-y-4 text-balance text-4xl font-display font-medium tracking-[-0.05em] text-[var(--text-color)] sm:text-6xl lg:text-7xl">
        <span>Human-first</span>
        <RotatingText client:only="react" />
      </h1>
      <p class="mt-8 text-lg md:text-xl text-[var(--text-muted)] max-w-3xl leading-relaxed">
        Field notes on AI systems, public sector digitization, orchestration, and evaluation for teams building where delivery pressure is real and fluff is expensive.
      </p>
      
      <!-- V2 Glowing Newsletter CTA -->
      <div class="mt-12 w-full max-w-md relative group">
      <div class="absolute -inset-1 bg-gradient-to-r from-primary-600 to-primary-400 rounded-2xl blur opacity-25 group-hover:opacity-60 transition duration-1000 group-hover:duration-300"></div>
      <div class="relative bg-[var(--bg-color)] p-1.5 rounded-xl shadow-[0_0_20px_rgba(34,197,94,0.3),0_0_40px_rgba(34,197,94,0.1)] border border-[var(--border-color)]">
        <form class="flex w-full relative" action="/newsletter" method="GET">
          <input 
            type="email" 
            name="email"
            placeholder="name@example.com" 
            required
            class="flex-grow bg-transparent px-4 py-3 outline-none text-[var(--text-color)] placeholder:text-[var(--text-muted)]/60"
          />
          <button 
            type="submit" 
            class="bg-[var(--text-color)] text-[var(--bg-color)] font-medium px-6 py-2 m-1 rounded-lg transition-transform hover:scale-[1.02] shadow-sm whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
      </div>
      </div>

      <div class="mt-8 flex items-center justify-center gap-3 text-xs font-medium text-[var(--text-muted)]">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-[var(--border-color)] bg-[var(--surface-color)] text-[10px] font-bold text-[var(--text-color)]">5K+</span>
        <span>Readers and operators following the weekly synthesis.</span>
      </div>
    </div>
  </section>

  <section class="py-8 border-y border-[var(--border-color)] bg-[color-mix(in_srgb,var(--surface-color)_78%,transparent)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <TrustedTicker />
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-[var(--border-color)] overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-display font-medium tracking-[-0.05em] text-[var(--text-color)] text-balance">
          From deployed work to reusable frameworks.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-[var(--text-muted)]">
          The core flywheel is simple: work inside live systems, distill the lessons into patterns, then teach what survives contact with reality. That is what turns scattered experience into signal.
        </p>
      </div>

      <ScrollPath client:only="react" />
    </div>
  </section>

  <!-- LATEST ARTICLES REGION -->
  <section class="py-12 border-t border-[var(--border-color)]">
    <div class="flex justify-between items-end mb-8">
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-[var(--text-color)]">Latest Analysis</h2>
        <p class="text-[var(--text-muted)] mt-1">Recent deep dives and tutorials.</p>
      </div>
      <a href="/blog" class="text-sm font-medium text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 hidden sm:block">
        View all articles &rarr;
      </a>
    </div>

    <!-- Article Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestPosts.length > 0 ? latestPosts.map((post) => (
        <SpotlightCard client:load className="flex flex-col group touch-pan-y cursor-pointer bg-[var(--bg-color)] border border-[var(--border-color)] rounded-2xl p-4 hover:-translate-y-1 hover:shadow-xl hover:scale-[1.02] transition-all duration-300">
          <a href={`/blog/${post.slug}`} class="absolute inset-0 z-10"><span class="sr-only">View {post.data.title}</span></a>
          {post.data.image && (
            <div class="aspect-video w-full rounded-xl bg-[var(--border-color)] overflow-hidden mb-5 relative transition-transform duration-500 group-hover:scale-[1.02]">
               <Image 
                src={post.data.image.src} 
                alt={post.data.image.alt}
                width={600}
                height={338}
                class="w-full h-full object-cover"
              />
            </div>
          )}
          <div class="flex items-center gap-2 mb-3 z-20 relative">
            {post.data.tags && post.data.tags.slice(0,1).map((tag: string) => (
              <a href={`/tags/${tag}`} class="text-[10px] font-bold uppercase tracking-wider px-2 py-1 bg-[var(--text-color)]/5 border border-[var(--text-color)]/20 text-[var(--text-color)] rounded-md hover:bg-primary-600/10 transition-colors">{tag}</a>
            ))}
            <span class="text-xs font-medium text-[var(--text-muted)]">
              {new Date(post.data.pubDate).toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric'})}
            </span>
          </div>
          <h3 class="text-xl font-display font-medium tracking-normal text-[var(--text-color)] group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2 line-clamp-2">
            {post.data.title}
          </h3>
          <p class="text-[var(--text-muted)] text-sm line-clamp-3 leading-relaxed">
            {post.data.description}
          </p>
        </SpotlightCard>
      )) : (
        <p class="col-span-full text-center py-10 text-[var(--text-muted)] border border-dashed border-[var(--border-color)] rounded-xl">
          More articles coming directly from the agents soon.
        </p>
      )}
    </div>
    
    <div class="mt-8 text-center sm:hidden">
      <a href="/blog" class="inline-flex items-center justify-center w-full bg-[var(--border-color)] hover:bg-[var(--bg-color)] text-[var(--text-color)] font-medium px-4 py-3 rounded-lg transition-colors border border-[var(--border-color)] focus:ring-2 focus:ring-primary-500 focus:outline-none">
        View all articles
      </a>
    </div>
  </section>
</BaseLayout>
