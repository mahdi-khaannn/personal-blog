---
import '../styles/global.css';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  schema?: string;
}

const { 
  title, 
  description = "Mahdi Khan Technical Content Platform - The practitioner's definitive source for AI agents analysis and tutorials", 
  image,
  canonicalURL,
  schema
} = Astro.props;

// Ensure stable fallback URL resolution
const ogImageURL = image 
  ? new URL(image, Astro.site || Astro.url) 
  : new URL('/images/og-default.webp', Astro.site || Astro.url);
const canonical = canonicalURL || new URL(Astro.url.pathname, Astro.site || Astro.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    {schema && <script type="application/ld+json" set:html={schema} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />

    <!-- Google Analytics (GA4) -->
    <!-- Note: Replace G-XXXXXXXXXX with actual tracking ID before launch -->
    <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    
    <!-- Setup Dark Mode Immediately to prevent flash -->
    <script is:inline>
      const STORAGE_KEY = 'theme';
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem(STORAGE_KEY);
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const applyThemePreference = () => {
        const isDark = getThemePreference() === 'dark';
        document.documentElement.classList.toggle('dark', isDark);
        document.documentElement.dataset.theme = isDark ? 'dark' : 'light';
        document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
      };

      applyThemePreference();

      if (!window.__themeEventsInitialized) {
        document.addEventListener('astro:after-swap', applyThemePreference);
        document.addEventListener('astro:page-load', applyThemePreference);
        window.__themeEventsInitialized = true;
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased selection:bg-primary-500/30 selection:text-primary-900 dark:selection:text-primary-50">
    <Header />
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
